# ──────────────────────────────────────────────────────────────────────────────
# Matrimonial API — required environment variables
#
# Copy this file to .env.local (gitignored) or set these as real env vars.
# ASP.NET Core reads nested keys using double-underscore separators, e.g.:
#   Jwt:Secret  →  Jwt__Secret
#   ConnectionStrings:Postgres  →  ConnectionStrings__Postgres
# ──────────────────────────────────────────────────────────────────────────────

# ASP.NET Core environment (Development | Staging | Production)
ASPNETCORE_ENVIRONMENT=Development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Use: openssl rand -base64 48
Jwt__Secret=REPLACE_WITH_AT_LEAST_32_CHAR_RANDOM_SECRET

# ── PostgreSQL ────────────────────────────────────────────────────────────────
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=matrimonial_saas;Username=postgres;Password=REPLACE_WITH_YOUR_PASSWORD

# ── MongoDB ───────────────────────────────────────────────────────────────────
# For local dev without auth this is already set in appsettings.Development.json.
# Override here for authenticated or remote instances.
MongoDB__ConnectionString=mongodb://localhost:27017
MongoDB__Database=matrimonial_profiles
