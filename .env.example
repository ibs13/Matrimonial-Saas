# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# PostgreSQL
POSTGRES_DB=matrimonial_db
POSTGRES_USER=matrimonial_user
POSTGRES_PASSWORD=change_me
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=matrimonial_db;Username=matrimonial_user;Password=change_me

# MongoDB
MONGO_USER=mongo_user
MONGO_PASSWORD=change_me
MONGO_DB=matrimonial_profiles
MONGODB_CONNECTION_STRING=mongodb://mongo_user:change_me@mongo:27017/matrimonial_profiles?authSource=admin

# JWT
JWT_SECRET=replace_with_long_secure_secret_min_32_chars
JWT_ISSUER=matrimonial-api
JWT_AUDIENCE=matrimonial-client
JWT_EXPIRY_MINUTES=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000